# ---- DuckDB / data ----
# DuckDB is the source of truth at runtime (binary, not tracked).
# Tracked CSVs (curated seeds + scraped snapshots) live in data/ and are
# version-controlled deliberately; only binaries / transient downloads are ignored.
*.duckdb
*.duckdb.wal
*.db
*.sqlite
*.sqlite3
*.parquet
*.xlsx

# Raw upstream events.json is a transient download (re-fetched each refresh).
events.json
data/events.json

# ---- Streamlit ----
.streamlit/secrets.toml

# ---- Secrets / env ----
.env
.env.*
*.key
secrets.toml

